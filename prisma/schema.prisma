// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Tier {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    AssignedProduct[]
  subscribers Subscriber[]
}

model AssignedProduct {
  id            String   @id @default(cuid())

  tierId        String
  tier          Tier     @relation(fields: [tierId], references: [id])

  sku           String
  productName   String

  forceInclude  Boolean  @default(false)

  createdAt     DateTime @default(now())
}

model PreferenceSubmission {
  id            String   @id @default(cuid())

  subscriberId  String?
  subscriber    Subscriber? @relation(fields: [subscriberId], references: [id])

  customerEmail String
  month         String
  size          String?
  style         String?
  notes         String?

  submittedAt   DateTime @default(now())
}

model Settings {
  id                      String   @id @default(cuid())

  automationEnabled       Boolean  @default(true)

  selectionDeadlineOffset Int      @default(7)
  autoSelectionOffset     Int      @default(2)
  orderCreationOffset     Int      @default(1)

  reminder14Days          Boolean  @default(true)
  reminder7Days           Boolean  @default(true)
  reminder3Days           Boolean  @default(true)
  reminder1Day            Boolean  @default(true)

  senderEmail             String?

  hideOutOfStock          Boolean  @default(true)
  hideDiscontinued        Boolean  @default(true)
  allowBackorders         Boolean  @default(false)

  autoCreateOrders        Boolean  @default(true)
  requireManualReview     Boolean  @default(false)

  autoOrderTag            String?  @default("SubscriptionSync-Auto")
  customerSelectedTag     String?  @default("MonthlySelection")
  modifiedOrderTag        String?  @default("AppstleSync")

  updatedAt               DateTime @updatedAt
}

model Subscriber {
  id                    String   @id @default(cuid())
  name                  String
  email                 String
  status                String   @default("Active")

  subscriptionStartDate DateTime
  nextShipDate          DateTime
  nextSelectionDeadline DateTime
  autoSelectionDate     DateTime?

  tierId                String?
  tier                  Tier?    @relation(fields: [tierId], references: [id])

  shipments             Shipment[]
  preferenceSubmissions PreferenceSubmission[]
  selections            Selection[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

 
}

model Shipment {
  id            String   @id @default(cuid())

  subscriberId  String
  subscriber    Subscriber @relation(fields: [subscriberId], references: [id])

  shipDate      DateTime
  status        String   @default("Pending")
  productName   String?
  trackingUrl   String?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Selection {
  id            String   @id @default(cuid())

  subscriberId  String
  subscriber    Subscriber @relation(fields: [subscriberId], references: [id])

  month         String
  status        String   @default("Pending")

  productName   String?
  source        String   @default("Customer Form")
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}